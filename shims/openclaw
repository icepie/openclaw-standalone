#!/bin/sh
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CHANGELOG_STUB="$SCRIPT_DIR/node_modules/@mariozechner/pi-coding-agent/dist/utils/changelog.js"

if [ ! -f "$CHANGELOG_STUB" ]; then
    mkdir -p "$(dirname "$CHANGELOG_STUB")"
    printf '%s\n' 'import { fileURLToPath } from "url"; import { dirname, join } from "path"; const __filename = fileURLToPath(import.meta.url); const __dirname = dirname(__filename); export const getChangelogPath = () => join(__dirname, "../../CHANGELOG.md"); export const parseChangelog = (content) => []; export const getNewEntries = async (lastVersion) => []; export const getLatestVersion = () => "0.52.12"; export const getChangelog = async () => [];' > "$CHANGELOG_STUB"
fi

exec "$SCRIPT_DIR/node" "$SCRIPT_DIR/node_modules/openclaw/openclaw.mjs" "$@"
